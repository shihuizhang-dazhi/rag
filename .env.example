# =====================
# 大模型 / 向量模型
# =====================
# 阿里云百炼（DashScope）兼容 OpenAI 协议的 API Key
OPENAI_API_KEY=sk-xxx
# OpenAI 兼容端点（百炼 maas）
OPENAI_BASE_URL=https://ws-10v53f71kp1ik6yu.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# 对话用模型名
OPENAI_MODEL_NAME=qwen3.7-plus
# Embedding 向量模型名
EMBEDDING_MODEL=text-embedding-v3

# =====================
# 文档解析 / 检索参数
# =====================
# 支持上传的扩展名（Python 列表字面量）
SUPPORTED_EXTENSIONS=[".txt",".pdf",".csv",".md"]
# 单块字符数（MD 文档按标题边界切，超此值补字符切）
CHUNK_SIZE=800
# 相邻块重叠字符数
CHUNK_OVERLAP=100
# 检索返回的 TopK
TOP_K=5
# 相关度阈值（低于此分数不返回）
SCORE_THRESHOLD=0.3

# =====================
# 文档存储 / 数据库 / 向量库路径
# =====================
# 单文件最大体积（MB）
MAX_FILE_SIZE_MB=50
# 原始上传文档保存目录
DOCUMENTS_SAVE_PATH=data/documents
# 文档元信息 SQLite 路径
DATABASE_FILE_PATH=data/docs.db
# Chroma 向量库持久化目录
CHROMA_PATH=data/chroma

# =====================
# 日志（logger.py 读取）
# =====================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days

# =====================
# 认证鉴权
# =====================
# JWT 签名密钥（部署时自动生成随机值，或手动填写）
JWT_SECRET=change-me-in-production-please

# =====================
# 安全 / CORS / 文档
# =====================
# 允许的 CORS 来源（Python 列表字面量），生产环境应设为具体域名如 ["https://yourdomain.com"]
CORS_ORIGINS=["*"]
# 是否启用 /docs /redoc /openapi.json（生产建议关闭）
ENABLE_DOCS=True
# Set-Cookie Secure 标志（仅 HTTPS 环境可设为 True）
COOKIE_SECURE=False
